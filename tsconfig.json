{
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "target": "es2020" /* Specify ECMAScript target version. */,
    "module": "node16" /* Module system — 'node16' sigue reglas de Node según package.json. */,
    "moduleResolution": "node16" /* Reemplazo moderno de 'node' (deprecated en TS 5.x). */,
    "lib": ["es2020"],
    "strict": true /* Enable all strict type-checking options. */,
    "isolatedModules": true /* Requerido por ts-jest con module: node16. */,
    "types": ["jest", "node"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "useUnknownInCatchVariables": false
  },
  "exclude": ["node_modules"]
}
